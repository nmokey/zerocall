{
  "name": "zerocall",
  "private": true,
  "description": "Your AI assistant reads the room before you ask.",
  "workspaces": ["harness", "server", "frontend-demo"],
  "scripts": {
    "build": "npm run build -w harness && npm run build -w server && npm run build -w frontend-demo",
    "build:harness": "npm run build -w harness",
    "build:server": "npm run build -w server",
    "build:frontend-demo": "npm run build -w frontend-demo",
    "dev:frontend-demo": "npm run dev -w frontend-demo",
    "start": "npm start -w server",
    "dev": "npm run dev -w server",
    "auth:google": "tsx scripts/google-auth.ts"
  },
  "devDependencies": {
    "dotenv": "latest",
    "tsx": "latest"
  }
}
